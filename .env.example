# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
APP_URL=http://localhost:3000

# ─── WhatsApp / Meta Cloud API ───────────────────────────────────────────────
# Get from: https://developers.facebook.com/ → Your App → WhatsApp → API Setup
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PHONE_NUMBER_ID=your_phone_number_id
META_ACCESS_TOKEN=your_permanent_access_token
META_VERIFY_TOKEN=choose_any_random_string_here

# ─── OpenAI (GPT-4o for jewelry analysis + caption writer + advisor) ──────────
OPENAI_API_KEY=sk-proj-lpJNgzF--XGjn-uVHkYunKa6JIFczdISeh17fWZQ7-oT3BlbkFJa06feY2OEtwi9uPacShtP8JEyV_nRG5XC7l433rig-sPw_5QUb6Tc_5anGCG1uFbLRUws6xzYA

# ─── Kie AI / NanoBanana 2 (image generation) ────────────────────────────────
KIE_AI_API_KEY=
KIE_AI_BASE_URL=https://api.kie.ai

# ─── Cloudinary (image storage + CDN) ────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── AWS S3 (cold archive — optional for MVP) ────────────────────────────────
AWS_S3_BUCKET=jewel-chatbot-archive
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# For local dev with docker-compose:
DATABASE_URL=postgresql://jewel:jewel_dev_pass@localhost:5432/jewel_chatbot

# ─── Redis ────────────────────────────────────────────────────────────────────
# For local dev with docker-compose:
REDIS_URL=redis://localhost:6379

# ─── Razorpay (payments — optional for MVP, required for monetization) ────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
